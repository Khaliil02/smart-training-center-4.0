# Development Dockerfile for Angular
# Supports ng serve with live reload

FROM node:20-alpine

WORKDIR /app

# Copy package files
COPY package.json package-lock.json ./

# Install dependencies
RUN npm ci

# Copy application code (will be overridden by volume mount)
COPY . .

EXPOSE 4200

# Development command: Run ng serve with live reload
# Disable browser option to prevent auto-opening in container
# Enable polling for file changes (needed in Docker volumes)
CMD ["ng", "serve", "--host", "0.0.0.0", "--poll", "2000", "--no-browser"]
